# DGB Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Optional legacy fallback if you are not using Supabase publishable keys yet.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required only for server-only admin maintenance/bootstrap scripts.
# Never expose this as NEXT_PUBLIC_* and never commit real values.
SUPABASE_SECRET_KEY=CHANGEME
